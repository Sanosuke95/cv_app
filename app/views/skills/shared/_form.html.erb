<%= form_with model: skill do |f| %>
  <div class="mb-3">
    <%= f.label :name, "Name", class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
    <% @skill.errors.full_messages_for(:name).each do |message| %>
      <div><%= message %></div>
    <% end %>
  </div>

  <div class="mb-3">
    <%= f.label :title, "level", class: "form-label" %>
    <%= f.select :level, options_for_select(0..5), {},class: "form-select" %>
  </div>

  <div>
    <%= f.submit 'Submit', class: "btn btn-primary" %>
  </div>

  <div></div>

  <div class="d-grid gap-2 d-md-flex justify-content-md-end">
    <%= link_to "Back", :back, class: 'btn btn-secondary', type: "button" %>
  </div>
<% end %>